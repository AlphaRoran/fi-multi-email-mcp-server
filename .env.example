# Preferred client-friendly setup:
# The local MCP points at your hosted OAuth broker. Provider OAuth app secrets live only on the broker.
EMAIL_MCP_AUTH_BASE_URL=
# Public key is safe to ship to clients. It verifies broker-signed OAuth handoffs.
EMAIL_MCP_BROKER_PUBLIC_KEY=
# Shared secret is only for local/dev fallback if you are not using broker public/private keys.
EMAIL_MCP_BROKER_SHARED_SECRET=

# Direct local OAuth fallback:
# Only needed if you are not using EMAIL_MCP_AUTH_BASE_URL.
# Runtime tokens are stored outside this repo in:
#   ~/.fender-industries/email-mcp/tokens.json

# Google Cloud OAuth client configured as a Desktop app or Web app with a loopback redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID app registration. Use "common" for multi-tenant personal/work accounts.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Optional overrides.
EMAIL_MCP_TOKEN_STORE=
EMAIL_MCP_OAUTH_HOST=127.0.0.1
EMAIL_MCP_OAUTH_PORT=8741

# Hosted broker runtime only:
# BROKER_PUBLIC_BASE_URL=https://auth.fenderindustries.com
# BROKER_PORT=8787
# BROKER_PRIVATE_KEY=
